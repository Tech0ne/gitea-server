# ============================================================
#   GITEA STACK — single configuration file
#   Edit the values below, then run:  ./start.sh   (or: make up)
#   Nothing else needs touching to get a working instance.
# ============================================================

# ---- Images / versions --------------------------------------
# Gitea MUST be >= 1.23 for the auto-registration token to work.
GITEA_IMAGE=gitea/gitea:1.26-rootless
RUNNER_IMAGE=gitea/runner:1.0-dind-rootless
POSTGRES_IMAGE=postgres:18-alpine

# ---- Host ports ---------------------------------------------
HTTP_PORT=3000            # web UI        -> http://localhost:3000
SSH_PORT=2222             # git over ssh  -> ssh://git@localhost:2222

# ---- Public URL (how browsers/clients reach Gitea) ----------
GITEA_DOMAIN=localhost
GITEA_ROOT_URL=http://localhost:3000/

# ---- Admin account (created automatically on first start) ---
GITEA_ADMIN_USER=admin
GITEA_ADMIN_PASSWORD=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
GITEA_ADMIN_EMAIL=admin@example.com

# ---- Database (PostgreSQL, runs in its own container) -------
POSTGRES_DB=gitea
POSTGRES_USER=gitea
POSTGRES_PASSWORD=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ---- Action runners -----------------------------------------
# How many runner containers to start. They all auto-register.
RUNNER_REPLICAS=1

# Reusable global registration token shared by Gitea + runners.
# MUST be exactly 40 characters. Leave it and the justfile
# will generate a proper one for you on first launch.
RUNNER_REGISTRATION_TOKEN=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Labels decide which container image each job runs in
# (GitHub-Actions-style: "<label>:docker://<image>").
RUNNER_LABELS=RUNNER_LABELS=ubuntu-latest:docker://docker.gitea.com/runner-images:ubuntu-latest,ubuntu-22.04:docker://docker.gitea.com/runner-images:ubuntu-22.04

# ---- Misc ---------------------------------------------------
TZ=Europe/Paris
